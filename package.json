{
  "name": "@codebygarv/express-lens",
  "version": "2.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "A lightweight, plug-and-play monitoring package for Express.js applications.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "types": "index.d.ts",
  "files": [
    "dist",
    "index.d.ts"
  ],
  "scripts": {
    "build": "tsup index.js --format cjs,esm --clean",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "express",
    "monitor",
    "monitoring",
    "metrics",
    "dashboard",
    "performance"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "express": "^4.22.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
